# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local dev example below; use your provider's
# pooled URL on Vercel, e.g. Neon / Supabase / Vercel Postgres).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salty_cowboy?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public origin of the deployed site (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# 32+ char random secret for signing admin sessions and booking magic links.
# Generate with: openssl rand -base64 48
AUTH_SECRET="REPLACE_WITH_openssl_rand_base64_48"

# Shared secret required by /api/cron/* endpoints (reminder emails).
CRON_SECRET="REPLACE_WITH_RANDOM_SECRET"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
# From `stripe listen` locally, or the webhook endpoint config in the dashboard.
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Leave RESEND_API_KEY unset in dev to log emails to the console instead.
RESEND_API_KEY=""
EMAIL_FROM="Salty Cowboy Adventures <bookings@saltycowboyadventures.com>"

# ─── Analytics (optional — analytics stay disabled until these are set) ─────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
